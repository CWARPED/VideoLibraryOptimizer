# Copy to .env and adjust. All variables are optional (sensible defaults apply).

# Paths
# VLO_DB_PATH=./data/vlo.db
# VLO_WORK_DIR=./work

# ffmpeg / ffprobe (defaults: found on PATH)
# VLO_FFMPEG_PATH=ffmpeg
# VLO_FFPROBE_PATH=ffprobe

# Scoring
# VLO_WEIGHT_OVERHEAD=0.5
# VLO_WEIGHT_GAIN=0.5
# VLO_GAIN_REF_GB=10.0
# VLO_MIN_OVERHEAD_RATIO=1.1

# Safety
# VLO_EXCLUDE_DOLBY_VISION=true
# VLO_DISK_SPACE_MARGIN_BYTES=5368709120
# VLO_DURATION_TOLERANCE_PCT=0.5

# Server
# VLO_HOST=127.0.0.1
# VLO_PORT=8077
